{
  "manifest_version": 3,
  "name": "Billet. — Quick Add",
  "version": "1.1.0",
  "description": "Quickly save jobs from LinkedIn, Indeed, Glassdoor, ZipRecruiter, RemoteOK, Wellfound and Monster directly to your Billet tracker.",
  "permissions": ["activeTab", "storage", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/jobs/*",
        "*://*.indeed.com/viewjob*",
        "*://*.indeed.com/*vjk=*",
        "*://*.indeed.com/jobs*",
        "*://*.glassdoor.com/Job/*",
        "*://*.glassdoor.com/job-listing/*",
        "*://*.glassdoor.com/job/*",
        "*://*.ziprecruiter.com/jobs/*",
        "*://*.ziprecruiter.com/jobs-search*",
        "*://*.ziprecruiter.com/job/*",
        "*://*.ziprecruiter.com/c/*",
        "*://*.dice.com/jobs/*",
        "*://*.dice.com/job/*",
        "*://remoteok.com/remote-jobs/*",
        "*://*.remoteok.com/remote-jobs/*",
        "*://remoteok.io/remote-jobs/*",
        "*://*.remoteok.io/remote-jobs/*",
        "*://wellfound.com/jobs/*",
        "*://wellfound.com/l/*",
        "*://*.angel.co/jobs/*",
        "*://*.monster.com/job-openings/*",
        "*://*.monster.com/jobs/*"
      ],
      "js": ["content.js"]
    }
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://billet-ng.vercel.app/*",
    "*://*.linkedin.com/*",
    "*://*.indeed.com/*",
    "*://*.glassdoor.com/*",
    "*://*.ziprecruiter.com/*",
    "*://*.dice.com/*",
    "*://remoteok.com/*",
    "*://*.remoteok.com/*",
    "*://remoteok.io/*",
    "*://*.remoteok.io/*",
    "*://wellfound.com/*",
    "*://*.angel.co/*",
    "*://*.monster.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "billet@kinggray034"
    }
  }
}